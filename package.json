{
	"name": "schulcloud-nuxt",
	"description": "The next Level of Dataport Bildungscloud",
	"author": "Dataport Bildungscloud",
	"private": true,
	"type": "module",
	"scripts": {
		"serve": "vite --host",
		"build": "run-p type-check \"build-only {@}\" --",
		"build-only": "vite build",
		"type-check": "vue-tsc --noEmit",
		"preview": "vite preview",
		"test": "npm run test:unit",
		"test:unit": "vitest run",
		"test:unit:watch": "vitest watch",
		"test:unit:ci": "vitest run --coverage",
		"lint": "eslint src/**/*.{ts,js,vue}",
		"lint:fix": "eslint src/**/*.{ts,js,vue} --fix",
		"generate-client:server": "openapi-generator-cli generate -c ./openapitools.json --generator-key server-api",
		"generate-client:fwu": "openapi-generator-cli generate -c ./openapitools.json --generator-key fwu-api",
		"generate-client:filestorage": "openapi-generator-cli generate -c ./openapitools.json --generator-key file-storage-api",
		"generate-client:h5p-editor": "openapi-generator-cli generate -c ./openapitools.json --generator-key h5p-editor-api",
		"generate-client:common-cartridge": "openapi-generator-cli generate -c ./openapitools.json --generator-key common-cartridge-api",
		"generate-client:notification": "openapi-generator-cli generate -c ./openapitools.json --generator-key notification-api"
	},
	"dependencies": {
		"@braintree/sanitize-url": "^7.1.2",
		"@ckeditor/ckeditor5-core": "^41.4.2",
		"@ckeditor/ckeditor5-vue": "^5.1.0",
		"@hpi-schul-cloud/ckeditor": "2.1.3",
		"@lumieducation/h5p-webcomponents": "^10.0.4",
		"@types/lodash-es": "^4.17.12",
		"@vueuse/components": "^14.3.0",
		"@vueuse/core": "^14.3.0",
		"@vueuse/integrations": "^14.3.0",
		"axios": "^1.18.1",
		"dayjs": "^1.11.21",
		"focus-trap": "^8.2.1",
		"katex": "^0.16.47",
		"lodash-es": "^4.18.1",
		"maska": "^3.2.0",
		"mobile-drag-drop": "2.3.0-rc.2",
		"pinia": "^3.0.4",
		"qrcode.vue": "^3.9.1",
		"rollup": "^4.60.4",
		"socket.io-client": "^4.8.3",
		"sortablejs": "^1.15.7",
		"sortablejs-vue3": "^1.3.0",
		"vue": "^3.5.34",
		"vue-dompurify-html": "^5.3.0",
		"vue-i18n": "^11.4.4",
		"vue-router": "^5.0.7",
		"vuedraggable": "^4.1.0",
		"vuetify": "^3.12.6",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@mdi/js": "^7.4.47",
		"@openapitools/openapi-generator-cli": "^2.38.0",
		"@pinia/testing": "^1.0.3",
		"@types/katex": "^0.16.8",
		"@types/sortablejs": "^1.15.9",
		"@vitejs/plugin-vue": "^6.0.7",
		"@vitest/coverage-v8": "^4.1.7",
		"@vue/eslint-config-typescript": "^14.7.0",
		"@vue/test-utils": "^2.4.10",
		"arg": "^5.0.2",
		"connect": "^3.7.0",
		"eslint": "^10.4.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-prettier": "^5.5.5",
		"eslint-plugin-simple-import-sort": "^13.0.0",
		"eslint-plugin-unused-imports": "^4.4.1",
		"eslint-plugin-vue": "^10.9.1",
		"fishery": "^2.4.0",
		"globals": "^17.6.0",
		"http-proxy-middleware": "^4.1.1",
		"jsdom": "^29.1.1",
		"npm-run-all2": "^9.0.1",
		"prettier": "^3.8.3",
		"resize-observer-polyfill": "^1.5.1",
		"sass-embedded": "^1.100.0",
		"socket.io": "^4.8.3",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.61.0",
		"vite": "^7.3.3",
		"vite-plugin-vue-devtools": "^8.1.2",
		"vite-plugin-vuetify": "^2.1.3",
		"vitest": "^4.1.7",
		"vitest-mock-extended": "^4.0.0",
		"vue-router-mock": "^2.0.2",
		"vue-tsc": "^3.3.7"
	},
	"overrides": {
		"@openapitools/openapi-generator-cli": {
			"axios": "$axios"
		}
	},
	"engines": {
		"node": "24",
		"npm": "11"
	}
}
